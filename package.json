{
  "name": "discactyl",
  "version": "1.0.0",
  "description": "Discord bot for Pterodactyl Panel control",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "deploy:dev": "ts-node src/deploy-commands.ts --guild",
    "deploy:prod": "ts-node src/deploy-commands.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0 || true"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^11.1.2",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "node-cache": "^5.1.2",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
